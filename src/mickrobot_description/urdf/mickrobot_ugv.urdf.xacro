        <box size="0.07 0.104 0.033" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2" />
      <origin xyz="0 0 0.0165" rpy="0 0 0" />
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4" />
    </inertial>
  </link>
  <joint name="top_payload_joint" type="fixed">
