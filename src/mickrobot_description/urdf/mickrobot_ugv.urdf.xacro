<?xml version="1.0"?>
<robot name="mickrobot" xmlns:xacro="http://ros.org/wiki/xacro">

  <link name="base_footprint">
    <visual>
      <geometry>
        <sphere radius="0.001" />
      </geometry>
      <material name="invisible">
        <color rgba="0 0 0 0" />
      </material>
    </visual>
  </link>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint" />
    <child link="base_link" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>
  <link name="top_payload_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://mickrobot_description/urdf/mesh/board_camera_radar_assembly.stl" scale="1 1 1" />
      </geometry>
      <material name="payload_dark">
        <color rgba="0.08 0.08 0.08 1" />
