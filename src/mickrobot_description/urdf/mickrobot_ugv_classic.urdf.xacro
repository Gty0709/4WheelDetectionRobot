<?xml version="1.0"?>
<robot name="mickrobot" xmlns:xacro="http://ros.org/wiki/xacro">

  <link name="base_footprint">
    <visual>
      <geometry>
        <sphere radius="0.001" />
      </geometry>
      <material name="invisible">
        <color rgba="0 0 0 0" />
      </material>
    </visual>
  </link>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint" />
    <child link="base_link" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>
  <link name="top_payload_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find mickrobot_description)/urdf/mesh/board_camera_radar_assembly.stl" scale="1 1 1" />
      </geometry>
      <material name="payload_dark">
        <color rgba="0.08 0.08 0.08 1" />
      </material>
    </visual>
    <inertial>
      <mass value="0.05" />
      <origin xyz="0 0 0.01" rpy="0 0 0" />
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5" />
    </inertial>
  </link>
  <joint name="top_payload_joint" type="fixed">
    <parent link="base_link" />
    <child link="top_payload_link" />
    <origin xyz="0 0 0.128031" rpy="0 0 0" />
  </joint>
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.082" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find mickrobot_description)/urdf/mesh/ugv01_body.STL" scale="0.001 0.001 0.001" />
      </geometry>
      <material name="chassis_gray">
        <color rgba="0.3 0.3 0.3 1" />
      </material>
    </visual>
    <!-- 窄腰碰撞：顶面 z≈0.12，低于雷达 z≈0.21，避免 360° 激光被自车遮挡 -->
    <collision>
      <origin xyz="0 0 0.095" rpy="0 0 0" />
      <geometry>
        <box size="0.16 0.12 0.05" />
      </geometry>
    </collision>
    <inertial>
      <mass value="7.0" />
      <origin xyz="0 0 0.055" rpy="0 0 0" />
      <inertia ixx="0.03" ixy="0" ixz="0" iyy="0.04" iyz="0" izz="0.05" />
    </inertial>
  </link>
  <link name="right_back_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079 0 0" />
      <geometry>
        <cylinder radius="0.04" length="0.03" />
      </geometry>
      <material name="wheel_black">
        <color rgba="0.1 0.1 0.1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079 0 0" />
      <geometry>
        <cylinder radius="0.04" length="0.03" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5" />
      <origin xyz="0 0 0" rpy="1.57079 0 0" />
      <inertia ixx="0.00024" ixy="0" ixz="0" iyy="0.00024" iyz="0" izz="0.0004" />
    </inertial>
  </link>
  <joint name="right_back_wheel_joint" type="continuous">
    <axis xyz="0 1 0" />
    <parent link="base_link" />
    <child link="right_back_wheel" />
    <origin xyz="-0.086 -0.09 0.04" />
    <limit effort="100" velocity="100" />
    <dynamics damping="0.2" friction="0.1" />
  </joint>
  <link name="right_front_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079 0 0" />
      <geometry>
        <cylinder radius="0.04" length="0.03" />
      </geometry>
      <material name="wheel_black">
        <color rgba="0.1 0.1 0.1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079 0 0" />
      <geometry>
        <cylinder radius="0.04" length="0.03" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5" />
      <origin xyz="0 0 0" rpy="1.57079 0 0" />
      <inertia ixx="0.00024" ixy="0" ixz="0" iyy="0.00024" iyz="0" izz="0.0004" />
    </inertial>
  </link>
  <joint name="right_front_wheel_joint" type="continuous">
    <axis xyz="0 1 0" />
    <parent link="base_link" />
    <child link="right_front_wheel" />
    <origin xyz="0.086 -0.09 0.04" />
    <limit effort="100" velocity="100" />
    <dynamics damping="0.2" friction="0.1" />
  </joint>
  <link name="left_back_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079 0 0" />
      <geometry>
        <cylinder radius="0.04" length="0.03" />
      </geometry>
      <material name="wheel_black">
        <color rgba="0.1 0.1 0.1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079 0 0" />
      <geometry>
        <cylinder radius="0.04" length="0.03" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5" />
      <origin xyz="0 0 0" rpy="1.57079 0 0" />
      <inertia ixx="0.00024" ixy="0" ixz="0" iyy="0.00024" iyz="0" izz="0.0004" />
    </inertial>
  </link>
  <joint name="left_back_wheel_joint" type="continuous">
    <axis xyz="0 1 0" />
    <parent link="base_link" />
    <child link="left_back_wheel" />
    <origin xyz="-0.086 0.09 0.04" />
    <limit effort="100" velocity="100" />
    <dynamics damping="0.2" friction="0.1" />
  </joint>
  <link name="left_front_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079 0 0" />
      <geometry>
        <cylinder radius="0.04" length="0.03" />
      </geometry>
      <material name="wheel_black">
        <color rgba="0.1 0.1 0.1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079 0 0" />
      <geometry>
        <cylinder radius="0.04" length="0.03" />
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5" />
      <origin xyz="0 0 0" rpy="1.57079 0 0" />
      <inertia ixx="0.00024" ixy="0" ixz="0" iyy="0.00024" iyz="0" izz="0.0004" />
    </inertial>
  </link>
  <joint name="left_front_wheel_joint" type="continuous">
    <axis xyz="0 1 0" />
    <parent link="base_link" />
    <child link="left_front_wheel" />
    <origin xyz="0.086 0.09 0.04" />
    <limit effort="100" velocity="100" />
    <dynamics damping="0.2" friction="0.1" />
  </joint>
  <!-- 中轮外观由 ugv01_body.STL 网格体现，不再单独建 link（避免 lump 成白圆柱） -->
  <link name="imu_link">
    <!-- 仅 IMU 传感器坐标系，无碰撞/外观，避免 lump 进 base 后白盒顶地 -->
    <inertial>
      <mass value="0.01" />
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6" />
    </inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link" />
    <child link="imu_link" />
    <origin xyz="0 0 0.09" rpy="0 0 0" />
  </joint>
  <link name="laser_link">
    <!-- 无碰撞：仅视觉+传感器坐标系 -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.038 0.038 0.012" />
      </geometry>
      <material name="lidar_base_blue">
        <color rgba="0.05 0.05 1.0 1" />
      </material>
    </visual>
    <inertial>
      <mass value="0.05" />
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5" />
    </inertial>
  </link>
  <joint name="laser_joint" type="fixed">
    <parent link="top_payload_link" />
    <child link="laser_link" />
    <!-- 置于顶板上方，高于底盘碰撞盒 -->
    <origin xyz="0 0 0.045" rpy="0 0 0" />
  </joint>
  <link name="camera_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.001 0.001 0.001" />
      </geometry>
      <material name="sensor_frame_invisible">
        <color rgba="0 0 0 0" />
      </material>
    </visual>
    <inertial>
      <mass value="0.001" />
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
    </inertial>
  </link>
  <joint name="camera_left_joint" type="fixed">
    <parent link="base_link" />
    <child link="camera_left_link" />
    <origin xyz="0.0357 0.007274 0.149031" rpy="0 0 0" />
  </joint>
  <link name="camera_rgb_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.001 0.001 0.001" />
      </geometry>
      <material name="sensor_frame_invisible">
        <color rgba="0 0 0 0" />
      </material>
    </visual>
    <inertial>
      <mass value="0.001" />
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
    </inertial>
  </link>
  <joint name="camera_rgb_joint" type="fixed">
    <parent link="base_link" />
    <child link="camera_rgb_link" />
    <origin xyz="0.0357 -0.0305 0.149031" rpy="0 0 0" />
  </joint>
  <!-- OAK 模组内置 IMU（与 RGB 光心不同位，见 joint 偏移） -->
  <link name="camera_imu_link">
    <visual>
      <geometry>
        <box size="0.001 0.001 0.001" />
      </geometry>
      <material name="sensor_frame_invisible">
        <color rgba="0 0 0 0" />
      </material>
    </visual>
    <inertial>
      <mass value="0.001" />
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
    </inertial>
  </link>
  <joint name="camera_imu_joint" type="fixed">
    <parent link="base_link" />
    <child link="camera_imu_link" />
  <!-- OAK-D IMU 约在模组中心，与 rgb/左目有毫米级偏差 -->
    <origin xyz="0.0357 -0.0315 0.149031" rpy="0 0 0" />
  </joint>
  <link name="camera_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.001 0.001 0.001" />
      </geometry>
      <material name="sensor_frame_invisible">
        <color rgba="0 0 0 0" />
      </material>
    </visual>
    <inertial>
      <mass value="0.001" />
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
    </inertial>
  </link>
  <joint name="camera_right_joint" type="fixed">
    <parent link="base_link" />
    <child link="camera_right_link" />
    <origin xyz="0.0357 -0.068274 0.149031" rpy="0 0 0" />
  </joint>

  <!-- [Humble迁移] 以下 Gazebo Classic 11 插件用于 Ubuntu 22.04 + Humble -->
  <!-- ==================== Gazebo Classic 插件 (Humble) ==================== -->

  <gazebo>
    <self_collide>false</self_collide>
  </gazebo>

  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <!-- 四驱：各向同性摩擦，避免 fdir1 导致前后轴侧向力不一致 -->
  <gazebo reference="left_front_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>5e4</kp>
    <kd>200</kd>
    <minDepth>0.002</minDepth>
  </gazebo>
  <gazebo reference="right_front_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>5e4</kp>
    <kd>200</kd>
    <minDepth>0.002</minDepth>
  </gazebo>
  <gazebo reference="left_back_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>5e4</kp>
    <kd>200</kd>
    <minDepth>0.002</minDepth>
  </gazebo>
  <gazebo reference="right_back_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>5e4</kp>
    <kd>200</kd>
    <minDepth>0.002</minDepth>
  </gazebo>

  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <remapping>odom:=/wheel/odom</remapping>
        <qos>
          <topic name="cmd_vel">
            <subscription>
              <durability>volatile</durability>
              <reliability>reliable</reliability>
            </subscription>
          </topic>
        </qos>
      </ros>
      <update_rate>50</update_rate>
      <!-- 前+后两轴真四驱（num_wheel_pairs=2，四轮独立驱动） -->
      <num_wheel_pairs>2</num_wheel_pairs>
      <left_joint>left_front_wheel_joint</left_joint>
      <right_joint>right_front_wheel_joint</right_joint>
      <left_joint>left_back_wheel_joint</left_joint>
      <right_joint>right_back_wheel_joint</right_joint>
      <wheel_separation>0.18</wheel_separation>
      <wheel_separation>0.18</wheel_separation>
      <wheel_diameter>0.08</wheel_diameter>
      <wheel_diameter>0.08</wheel_diameter>
      <max_wheel_torque>30</max_wheel_torque>
      <max_wheel_acceleration>5.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>false</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
  </gazebo>

  <!-- 四轮关节角 → /joint_states，供 RViz RobotModel 与实车一致 -->
  <gazebo>
    <plugin name="joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <ros>
        <remapping>joint_states:=joint_states</remapping>
      </ros>
      <update_rate>30</update_rate>
      <joint_name>left_front_wheel_joint</joint_name>
      <joint_name>left_back_wheel_joint</joint_name>
      <joint_name>right_front_wheel_joint</joint_name>
      <joint_name>right_back_wheel_joint</joint_name>
    </plugin>
  </gazebo>

  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0</mean><stddev>2e-4</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>2e-4</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>2e-4</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0</mean><stddev>1.7e-2</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>1.7e-2</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>1.7e-2</stddev></noise></z>
        </linear_acceleration>
      </imu>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <remapping>~/out:=imu/data</remapping>
        </ros>
        <frame_name>imu_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="camera_imu_link">
    <sensor name="camera_imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0</mean><stddev>2e-4</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>2e-4</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>2e-4</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0</mean><stddev>1.7e-2</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>1.7e-2</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>1.7e-2</stddev></noise></z>
        </linear_acceleration>
      </imu>
      <plugin name="camera_imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <remapping>~/out:=camera/imu/data</remapping>
        </ros>
        <frame_name>camera_imu_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="camera_left_link">
    <sensor name="camera_left_sensor" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>
      <plugin name="camera_left_plugin" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>camera</namespace>
        </ros>
        <camera_name>left</camera_name>
        <frame_name>camera_left_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="camera_right_link">
    <sensor name="camera_right_sensor" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>
      <plugin name="camera_right_plugin" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>camera</namespace>
        </ros>
        <camera_name>right</camera_name>
        <frame_name>camera_right_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="laser_link">
    <material>Gazebo/Blue</material>
    <sensor name="lidar" type="ray">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <visualize>true</visualize>
      <pose>0 0 0.01 0 0 0</pose>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="laser_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>laser_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

</robot>
