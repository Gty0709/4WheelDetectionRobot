<?xml version="1.0"?>
<robot name="mickrobot" xmlns:xacro="http://ros.org/wiki/xacro">
 
  <link name="base_footprint">
    <visual>
      <geometry>
        <sphere radius="0.001" />  
      </geometry>
      <material name="invisible">
        <color rgba="0 0 0 0"/>  
      </material>
    </visual>
  </link>

<joint name="base_joint" type="fixed">
  <parent link="base_footprint"/>
  <child link="base_link"/>
  <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
</joint>


  <!-- base -->
 <link name="base_link">
    <visual>
      <origin xyz="-0.3 -0.1665 0.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find mickrobot_description)/urdf/mesh/mickx4_body.STL" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0.0 0.0 0.08" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.333 0.16"/>
      </geometry>
    </collision>

   <inertial>
      <mass value="25"/>
      <origin xyz="0.0 0.0 0.08" rpy="0 0 0"/>
      <inertia 
        ixx="0.284" ixy="0" ixz="0"  
        iyy="0.803" iyz="0"           
        izz="0.981"/>
    </inertial>
  </link>
  
  <!-- right_back_wheel -->
  <link   name="right_back_wheel">
    <visual>
      <origin xyz="0.12 0 -0.11" rpy="0 0 1.57079"/>
      <geometry>
        <mesh filename="file://$(find mickrobot_description)/urdf/mesh/mickx4_wheel_8inches_2.STL" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0.035 0" rpy="0 1.57079 -1.57079"/>
      <geometry>
        <cylinder radius="0.1016" length="0.06"/>
      </geometry>
    </collision>
    
    <inertial>  
      <mass value="1"/>
      <origin xyz="-0 0.035 0" rpy="0 1.57079 -1.57079"/>
      <inertia ixx="0.00288" ixy="0.0" ixz="0.0" iyy="0.00288" iyz="0.0" izz="0.00516"/>
    </inertial>
  </link>
聽
  <joint   name="right_back_wheel_joint" type="continuous">
    <axis xyz="0 1 0"/>
    <parent   link="base_link"/>
    <child   link="right_back_wheel"/>
    <origin   xyz="-0.2 -0.26 0.0"/>
    <limit effort="100"   velocity="100"/>
  </joint>
  <!-- right_front_wheel -->
  
  <link   name="right_front_wheel">
    <visual>
      <origin xyz="0.12 0 -0.11" rpy="0 0 1.57079"/>
      <geometry>
        <mesh filename="file://$(find mickrobot_description)/urdf/mesh/mickx4_wheel_8inches_2.STL" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="-0 0.035 0" rpy="0 1.57079 -1.57079"/>
      <geometry>
        <cylinder radius="0.1016" length="0.06"/>
      </geometry>
    </collision>
    
    <inertial>  
      <mass value="1"/>
      <origin xyz="-0 0.035 0" rpy="0 1.57079 -1.57079"/>
      <inertia ixx="0.00288" ixy="0.0" ixz="0.0" iyy="0.00288" iyz="0.0" izz="0.00516"/>
    </inertial>
  </link>
聽
  <joint   name="right_front_wheel_joint" type="continuous">
    <axis xyz="0 1 0"/>
    <parent   link="base_link"/>
    <child   link="right_front_wheel"/>
    <origin   xyz="0.2 -0.26 0.0"/>
    <limit effort="100"   velocity="100"/>
  </joint>
  
  <!-- left_back_wheel -->
  <link   name="left_back_wheel">
    <visual>
      <origin xyz="-0.12 0 -0.11" rpy="0 0 -1.57079"/>
      <geometry>
        <mesh filename="file://$(find mickrobot_description)/urdf/mesh/mickx4_wheel_8inches_2.STL" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 -0.035 0" rpy="0 1.57079 -1.57079"/>
      <geometry>
        <cylinder radius="0.1016" length="0.06"/>
      </geometry>
    </collision>

    <inertial>  
      <mass value="1"/>
      <origin xyz="0 -0.035 0" rpy="0 1.57079 -1.57079"/>
      <inertia ixx="0.00288" ixy="0.0" ixz="0.0" iyy="0.00288" iyz="0.0" izz="0.00516"/>
    </inertial>
  </link>
聽
  <joint   name="left_back_wheel_joint" type="continuous">
    <axis xyz="0 1 0"/>
    <parent   link="base_link"/>
    <child   link="left_back_wheel"/>
    <origin   xyz="-0.2 0.26 0.0"/>
    <limit effort="100"   velocity="100"/>
  </joint> 
  
  <!-- left_front_wheel -->
  <link   name="left_front_wheel">
    <visual>
      <origin xyz="-0.12 0 -0.11" rpy="0 0 -1.57079"/>
      <geometry>
        <mesh filename="file://$(find mickrobot_description)/urdf/mesh/mickx4_wheel_8inches_2.STL" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 -0.035 0" rpy="0 1.57079 -1.57079"/>
      <geometry>
        <cylinder radius="0.1016" length="0.06"/>
      </geometry>
    </collision>

    <inertial>  
      <mass value="1"/>
      <origin xyz="0 -0.035 0" rpy="0 1.57079 -1.57079"/>
      <inertia ixx="0.00288" ixy="0.0" ixz="0.0" iyy="0.00288" iyz="0.0" izz="0.00516"/>
    </inertial>
  </link>
聽
  <joint   name="left_front_wheel_joint" type="continuous">
    <axis xyz="0 1 0"/>
    <parent   link="base_link"/>
    <child   link="left_front_wheel"/>
    <origin   xyz="0.2 0.26 0.0"/>
    <limit effort="100"   velocity="100"/>
  </joint> 
  
  <!-- sensor -->
  <link   name="sensor_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find mickrobot_description)/urdf/mesh/mickx4_sensorkit1.STL" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0.12 0.12 0.1" rpy="0 0 0 "/>
      <geometry>
        <box size="0.09 0.12 0.20"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="1"/>
      <origin xyz="0.12 0.12 0.05" rpy="0 0 0"/>
      <inertia ixx="0.00333" ixy="0.0" ixz="0.0" iyy="0.00333" iyz="0.0" izz="0.00240"/>
    </inertial>
  </link>
聽
  <joint   name="sensor_joint" type="fixed">  
    <parent   link="base_link"/>
    <child   link="sensor_link"/>
    <origin   xyz="0.09 -0.1165 0.16"/>
  </joint>
  
  <!-- imu -->
   <link name="imu_link">
    <visual>
    <origin xyz="0 0 0.0" rpy="0 0 0"/>
    <geometry>
          <box size="0.07 0.07 0.02"/>
    </geometry>
  </visual>

  <collision>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <geometry>
      <box size="0.07 0.07 0.02"/>
    </geometry>
  </collision>

    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <mass value="0.5"/>
      <inertia ixx="3.333e-5" ixy="0.0" ixz="0.0" iyy="3.333e-5" iyz="0.0" izz="3.333e-5"/>
    </inertial>
    </link>
  
  <joint name="imu_joint" type="fixed">
    <parent link="base_link" />
    <child link="imu_link" />
    <origin xyz="0.23 0.0 0.27" rpy="0.0 0.0 0.0" />
  </joint>


  
  <!-- gnss -->
  <link name="gnss_link">
    <visual>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.02"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.02 0.02 0.02"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <mass value="0.5"/>
      <inertia ixx="3.333e-5" ixy="0.0" ixz="0.0" iyy="3.333e-5" iyz="0.0" izz="3.333e-5"/>
    </inertial>
  </link>

  <joint name="gnss_joint" type="fixed">
    <parent link="base_link" />
    <child link="gnss_link" />
    <origin xyz="0.235 0.0 0.42" rpy="0.0 0.0 0.0" />
  </joint>

  <!-- laser -->
  <link name="laser_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.04"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.04"/> 
      </geometry>
    </collision>

    <inertial>
      <mass value="0.1"/>
      <inertia ixx="6.083e-5" ixy="0" ixz="0" iyy="6.083e-5" iyz="0" izz="8.0e-5"/>
    </inertial>
  </link>
  
  <joint name="laser_joint" type="fixed">
      <parent link="base_link" />
      <child link="laser_link" />
      <origin xyz="0.23 0.0 0.38" />
  </joint>
  
  <!-- camera -->
 <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.09 0.03"/>
      </geometry>
    </visual>
    
  <inertial>
  <mass value="0.1"/>
  <origin xyz="0 0 0" rpy="0 0 0"/>
  <inertia 
    ixx="4.167e-5" ixy="0" ixz="0"
    iyy="4.167e-5" iyz="0"
    izz="4.167e-5"
  />
  </inertial>
       
   <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.2 0.09 0.03"/>
      </geometry>
    </collision>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.29 0.0 0.31" rpy="0 0 0"/>
  </joint>

  <!-- diff_drive_plugin for gz-sim -->


<gazebo reference="left_front_wheel">
  <mu1>1.8</mu1> <!-- 闈欐懇鎿︾郴鏁?-->
  <mu2>4.0</mu2> <!-- 鍔ㄦ懇鎿︾郴鏁?-->
</gazebo>

<gazebo reference="right_front_wheel">
  <mu1>1.8</mu1>
  <mu2>4.0</mu2>
</gazebo>

<gazebo reference="left_back_wheel">
  <mu1>1.8</mu1>
  <mu2>4.0</mu2>
</gazebo>

<gazebo reference="right_back_wheel">
  <mu1>1.8</mu1>
  <mu2>4.0</mu2>
</gazebo>
  
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <!-- 宸﹀彸渚ц疆鐨勭粦瀹?-->
      <left_joint>left_front_wheel_joint</left_joint>
      <left_joint>left_back_wheel_joint</left_joint>
      <right_joint>right_front_wheel_joint</right_joint>
      <right_joint>right_back_wheel_joint</right_joint>

      <!-- Kinematics -->
      <wheel_separation>0.40</wheel_separation>
      <wheel_radius>0.1016</wheel_radius>

      <!-- limits -->
      <max_linear_acceleration>5.0</max_linear_acceleration>
      <max_angular_acceleration>5.0</max_angular_acceleration>

      <!-- topic -->
      <topic>cmd_vel</topic>

      <!-- output -->
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publish_frequency>30</odom_publish_frequency>
    </plugin>   

    <!-- Publish joint states -->
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
    </plugin>
  </gazebo>

  <!-- imu_plugin -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>imu/data</topic>
    </sensor>
  </gazebo>
  
  <!-- camera_plugin -->
  <gazebo reference="camera_link">
    <sensor name="camera_sensor" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>camera/image_raw</topic>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>
  
  <!-- gnss_plugin -->
  <gazebo reference="gnss_link">
    <sensor name="gnss_sensor" type="navsat">
      <always_on>true</always_on>
      <update_rate>5.0</update_rate>
      <topic>gps/fix</topic>
    </sensor>
  </gazebo>

  <!-- laser_plugin -->
  <gazebo reference="laser_link">
    <material>Gazebo/Blue</material>
    <sensor name="lidar" type="gpu_lidar">
        <pose>0 0 0 0 0 0</pose>
        <always_on>true</always_on>
        <visualize>true</visualize>
        <update_rate>10</update_rate>
        <topic>scan</topic>
        <ray>
            <scan>
                <horizontal>
                    <samples>360</samples>
                    <resolution>1</resolution>
                    <min_angle>-3.14159</min_angle>
                    <max_angle>3.14159</max_angle>
                </horizontal>
            </scan>
            <range>
                <min>0.3</min>
                <max>12.0</max>
                <resolution>0.01</resolution>
            </range>
        </ray>
    </sensor>
  </gazebo>
   
</robot>
